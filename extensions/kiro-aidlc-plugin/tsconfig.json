{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "out",
    "rootDir": "src",
    "lib": ["ES2020"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "aidlc-shared": ["./node_modules/aidlc-shared/out/index"]
    },
    "baseUrl": "."
  },
  "include": ["src/**/*"]
}
