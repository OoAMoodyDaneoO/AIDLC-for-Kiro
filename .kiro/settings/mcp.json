{
  "mcpServers": {
    "jira-pm": {
      "command": "uvx",
      "args": [
        "mcp-atlassian"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": []
    },
    "ado-pm": {
      "command": "npx",
      "args": [
        "-y",
        "azure-devops-mcp"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": []
    }
  }
}